# === Banco ===
POSTGRES_USER=leadgen
POSTGRES_PASSWORD=leadgen
POSTGRES_DB=leadgen
POSTGRES_HOST=db
POSTGRES_PORT=5432

# === Google Places API (New) — OPCIONAL ===
# Só é necessária para o comando `search` (busca automática). Importar listas manuais,
# enriquecer via crawler, exportar e relatórios funcionam sem esta chave. Deixe vazia se não usar.
# https://console.cloud.google.com/ → ativar "Places API (New)" → criar chave
GOOGLE_PLACES_API_KEY=

# === Coleta ===
SEARCH_CITY=São Paulo
SEARCH_REGION_CODE=BR
SEARCH_LANGUAGE=pt-BR
MAX_RESULTS_PER_QUERY=120          # Places retorna até 60 (3 páginas de 20); use múltiplas queries p/ mais
REQUEST_TIMEOUT=20
RATE_LIMIT_RPS=5                   # requisições por segundo (politeness)

# === LGPD ===
# Base legal padrão para contatos B2B coletados publicamente
DEFAULT_LEGAL_BASIS=legitimo_interesse_art_7_IX

# === LLM opcional (Fase 6 decisores / Bônus mensagens) ===
LLM_PROVIDER=                      # vazio = desligado | anthropic | openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_MODEL=claude-sonnet-4-6
